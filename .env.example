# =============================================================================
# ntutec-platform Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in actual values.
# DO NOT commit .env.local to version control.
# =============================================================================

# --- Supabase (Required) ---
# Project URL from Supabase dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Anon/public key from Supabase dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key (server-side only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- App Metadata (Optional) ---
NEXT_PUBLIC_APP_NAME=NTUTEC Platform
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Email / SMTP (Required for email notifications) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
# Sender address (default: noreply@tec.ntu.edu.tw)
SMTP_FROM=noreply@tec.ntu.edu.tw
# Contact form recipient (default: tec@ntu.edu.tw)
CONTACT_EMAIL=tec@ntu.edu.tw

# --- Telegram Bot (Required for Telegram push notifications — F-008) ---
# Bot token from @BotFather (same token used by Rigi Bot in ntutec-telegram)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Per-user routing: set investors.telegram_chat_id for each angel member
# Admin/system-wide fallback chat ID (Howard): 1335720750

# --- Google Analytics 4 (Optional) ---
# GA4 Measurement ID from Google Analytics > Admin > Data Streams
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# --- Google Search Console (Optional) ---
# HTML tag verification token from GSC > Settings > Ownership verification > HTML tag
# Copy only the content="" value (not the full meta tag)
NEXT_PUBLIC_GSC_VERIFICATION=your-gsc-verification-token
